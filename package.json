{
  "name": "vino-properties",
  "version": "1.0.0",
  "description": "vino.properties — Sri Lanka real estate platform on Cloudflare Workers + D1 + R2",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute vino-db --file=schema.sql --remote",
    "db:init:local": "wrangler d1 execute vino-db --file=schema.sql",
    "db:query": "wrangler d1 execute vino-db --remote --command"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
